datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 String    @default("SDR")
  isActive             Boolean   @default(true)
  phone                String?
  processosMonitorados String?
  accounts             Account[]
  sessions             Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id            String               @id @default(cuid())
  cnpj          String               @unique
  nome          String
  valorDivida   String?
  situacao      String?
  telefone      String?
  email         String?
  endereco      String?
  origem        String               @default("PGFN")
  status        String               @default("NOVO")
  responsavelId String?
  criadoEm      DateTime             @default(now())
  atualizadoEm  DateTime             @updatedAt
  processos     ProcessoMonitorado[]
}

model PipelineAtivo {
  id             String    @id @default(cuid())
  leadId         String
  tipo           String
  tribunal       String?
  valorCausa     String?
  fase           String?
  stage          String    @default("PROSPECÇÃO")
  linkProcesso   String?
  responsavelId  String?
  dataFechamento DateTime?
  comissao       Float?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt
}

model ConsultaProcessualRun {
  id                 String    @id @default(cuid())
  startedAt          DateTime  @default(now())
  finishedAt         DateTime?
  status             String    @default("RUNNING")
  totalProcessos     Int       @default(0)
  consultados        Int       @default(0)
  novasMovimentacoes Int       @default(0)
  erros              Int       @default(0)
  detalhes           String?
}

model ProcessoMonitorado {
  id                      String                   @id @default(cuid())
  numeroProcesso          String                   @unique
  tribunal                String?
  cliente                 String?
  responsavelNome         String?
  origemArquivo           String?
  status                  String                   @default("ATIVO")
  statusConsulta          String                   @default("PENDENTE")
  ultimaConsultaAt        DateTime?
  ultimaMovimentacaoAt    DateTime?
  ultimaMovimentacaoTexto String?
  leadId                  String?
  observacoes             String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  movimentacoes           MovimentacaoMonitorada[]
  lead                    Lead?                    @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([statusConsulta])
  @@index([status])
  @@index([tribunal])
}

model MovimentacaoMonitorada {
  id                   String             @id @default(cuid())
  processoMonitoradoId String
  dataMovimento        DateTime?
  descricao            String
  hash                 String
  fonte                String?
  nova                 Boolean            @default(true)
  visualizada          Boolean            @default(false)
  createdAt            DateTime           @default(now())
  processo             ProcessoMonitorado @relation(fields: [processoMonitoradoId], references: [id], onDelete: Cascade)

  @@unique([processoMonitoradoId, hash])
  @@index([nova])
  @@index([processoMonitoradoId])
  @@index([visualizada])
}
