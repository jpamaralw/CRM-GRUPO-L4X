datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id            String   @id @default(cuid())
  cnpj          String   @unique
  nome          String
  valorDivida   String?
  situacao      String?
  telefone      String?
  email         String?
  endereco      String?
  origem        String   @default("PGFN")
  status        String   @default("NOVO")
  responsavelId String?
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt
}

model PipelineAtivo {
  id             String    @id @default(cuid())
  leadId         String
  tipo           String
  tribunal       String?
  valorCausa     String?
  fase           String?
  stage          String    @default("PROSPECÇÃO")
  responsavelId  String?
  dataFechamento DateTime?
  comissao       Float?
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt
}
